# Ringdown — configuration. Copy to .env (chmod 600). scripts/provision-db.sh
# fills RINGDOWN_DB_DSN. Secrets here are treated like the DB password.

# --- storage -----------------------------------------------------------------
RINGDOWN_DB_DSN=postgresql://ringdown:<password>@<db-host>:5432/ringdown
RINGDOWN_EMBED_DIM=768                 # must match schema vector(N) + the embedder

# --- collector / ingest ------------------------------------------------------
RINGDOWN_SYSLOG_UDP=0.0.0.0:514        # empty to disable a listener
RINGDOWN_SYSLOG_TCP=0.0.0.0:514
RINGDOWN_BATCH_MAX=500
RINGDOWN_BATCH_MS=1000
RINGDOWN_QUEUE_MAX=50000

# --- router / loop-guard -----------------------------------------------------
RINGDOWN_INCIDENT_REUSE_TTL=7200       # reuse an open handle within this many seconds
RINGDOWN_FEED_INTERVAL=60              # min seconds between feeds to one handle
RINGDOWN_GLOBAL_RATE_CEILING=120       # max stateful (agent) opens/min across ALL rules

# --- turnstone dispatcher (owner-OBO) ----------------------------------------
# The admin token is the AUTHORITY to mint per-owner run-as tokens; it is never
# the acting identity of a workstream. Keep it as sensitive as the DB password.
RINGDOWN_TURNSTONE_URL=http://127.0.0.1:8090   # the CONSOLE (workers are :8080 — don't point here)
RINGDOWN_TURNSTONE_ADMIN_TOKEN=        # ts_… admin token that can mint /admin/users/{id}/tokens
RINGDOWN_TURNSTONE_DEFAULT_OWNER=      # fallback turnstone user_id for ownerless/system rules
RINGDOWN_TURNSTONE_TOKEN_TTL_HOURS=20
RINGDOWN_OBO_SCOPES=read,write         # scopes on the minted run-as token; excludes 'approve' by
                                      # design (destructive remediation stays behind the human gate)

# --- ntfy dispatcher + fallback (PUBLIC topic — safe by construction) --------
RINGDOWN_NTFY_URL=                     # e.g. https://ntfy.example.com  (empty = ntfy disabled)
RINGDOWN_NTFY_TOKEN=
RINGDOWN_NTFY_TOPIC=ringdown
RINGDOWN_FALLBACK_NTFY_TOPIC=          # where degraded dispatches page (default: RINGDOWN_NTFY_TOPIC)
RINGDOWN_NTFY_ALLOWED_HOSTS=          # SSRF guard: extra hostnames a per-target ntfy `url` may use,
                                      # beyond the RINGDOWN_NTFY_URL host (csv). Empty = only that host.

# --- L2 semantic judge (optional; empty = regex-only, no LLM tier) -----------
RINGDOWN_LLM_URL=                      # OpenAI-compatible /chat/completions base
RINGDOWN_LLM_MODEL=agent
RINGDOWN_LLM_API_KEY=
RINGDOWN_LLM_TEMPERATURE=              # OMIT to use the model's own generation_config recipe (recommended);
                                      # set only to pin a temp for a specific loaded model per its HF card
RINGDOWN_SEMANTIC_OUTAGE_ALERT_S=86400 # push ONE ntfy if the LLM is unreachable this long (24h); 0=off
RINGDOWN_SEMANTIC_TICK=30              # judge loop tick (s) — how often rules are checked for eligibility
RINGDOWN_SEMANTIC_SPIKE=100            # per-rule NEW-line burst (from the rule's scope) -> judge early
RINGDOWN_SEMANTIC_MIN_INTERVAL=300     # token floor: never judge one rule more often than this, even on a spike
RINGDOWN_SEMANTIC_MAX_PER_MIN=20       # global cap: max judge LLM calls/min across all rules (0 = off)

# --- MCP control-plane front door (Entra bearer token validation) ------------
RINGDOWN_PUBLIC_HOST=localhost
RINGDOWN_PORT=8787
RINGDOWN_TENANT_ID=                    # Entra tenant GUID
RINGDOWN_CLIENT_ID=                    # Ringdown app-reg GUID (token audience)
RINGDOWN_AUDIENCE=
RINGDOWN_REQUIRED_SCOPE=               # coarse "valid caller" scope
RINGDOWN_ALLOWED_CLIENTS=              # csv of calling client app ids (turnstone)
RINGDOWN_OPERATORS=                    # csv of oids/UPNs with break-glass (or use the Ringdown.Operator role)
RINGDOWN_AUDIT_LOG=/var/log/ringdown/audit.log
RINGDOWN_MAX_OUTPUT_CHARS=60000
RINGDOWN_DEFAULT_LIMIT=200
RINGDOWN_MAX_LIMIT=2000

# --- admin WebUI (interactive Entra SSO, certificate client-auth) -------------
RINGDOWN_WEBUI_PORT=8088
RINGDOWN_OIDC_REDIRECT_URI=https://ringdown.example.com/auth/callback
RINGDOWN_OIDC_KEY_PATH=/opt/ringdown/oidc/oidc.key   # private key (0600, never leaves box)
RINGDOWN_OIDC_CERT_PATH=/opt/ringdown/oidc/oidc.crt  # public cert (uploaded to app reg)
RINGDOWN_SESSION_SECRET=                             # openssl rand -hex 32
RINGDOWN_SESSION_TTL_HOURS=8
RINGDOWN_WEBUI_ADMIN_ROLE=Ringdown.Admin
